# Normaliza fim de linha: LF no repositório (o build do Netlify roda em Linux).
* text=auto eol=lf

# Scripts do Windows ficam em CRLF.
*.ps1 text eol=crlf

# Binários — nunca converter fim de linha.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.avif binary
*.gif binary
*.ico binary
*.mp4 binary
*.woff binary
*.woff2 binary
